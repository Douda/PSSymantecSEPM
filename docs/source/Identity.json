  "paths": {
    "/api/v1/identity/authenticate": {
      "post": {
        "tags": [
          "production"
        ],
        "summary": "Authenticates and returns an access token for a valid user.",
        "description": "",
        "operationId": "Authenticate User",
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "description": "The credentials used to log on to Symantec Endpoint Protection Manager.",
            "required": true,
            "schema": {
              "$ref": "#/definitions/UserCredential"
            }
          },
          {
            "name": "getBanner",
            "in": "query",
            "description": "Displays a logon banner, if configured. The possible values are TRUE or FALSE.",
            "required": false,
            "type": "string"
          },
          {
            "name": "appName",
            "in": "query",
            "description": "Specify an application name to receive a token unique for that app",
            "required": false,
            "type": "string"
          },
          {
            "in": "body",
            "name": "body",
            "required": false,
            "schema": {
              "$ref": "#/definitions/HttpServletRequest"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "The service successfully processed the web request and returned a result.",
            "schema": {
              "$ref": "#/definitions/UserToken"
            }
          },
          "400": {
            "description": "The parameters are invalid."
          },
          "401": {
            "description": "The user that is currently logged on has insufficient rights to execute the web method, or the user is unauthorized."
          },
          "404": {
            "description": "The requested resource was not found."
          },
          "500": {
            "description": "The web service encountered an error while processing the web request."
          }
        }
      }
    },
    "/api/v1/identity/logout": {
      "post": {
        "tags": [
          "production"
        ],
        "summary": "Logs off the user that is associated with a specified token.",
        "description": "",
        "operationId": "Logout",
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "required": false,
            "schema": {
              "$ref": "#/definitions/HttpServletRequest"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Log off is successful."
          },
          "400": {
            "description": "The parameters are invalid."
          },
          "401": {
            "description": "The user that is currently logged on has insufficient rights to execute the web method, or the user is unauthorized."
          },
          "404": {
            "description": "The requested resource was not found."
          },
          "500": {
            "description": "The web service encountered an error while processing the web request."
          }
        }
      }
    }
  },
