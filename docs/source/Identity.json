    "UserCredential": {
      "type": "object",
      "required": [
        "domain",
        "password",
        "username"
      ],
      "properties": {
        "username": {
          "type": "string",
          "description": "The username used to log on to Symantec Endpoint Protection Manager."
        },
        "password": {
          "type": "string",
          "description": "The encrypted password to use with the username."
        },
        "domain": {
          "type": "string",
          "description": "The Symantec Endpoint Protection Manager domain to which the username logs on."
        }
      }
    },
    "UserPermission": {
      "type": "object",
      "properties": {
        "reportingRights": {
          "type": "boolean",
          "description": "Specifies whether or not the user has reporting rights.",
          "default": false
        },
        "groupRights": {
          "type": "boolean",
          "description": "Specifies whether or not the user has group rights.",
          "default": false
        },
        "siteRights": {
          "type": "boolean",
          "description": "Specifies whether or not the user has site rights.",
          "default": false
        },
        "remoteCommandRights": {
          "type": "boolean",
          "description": "Specifies whether or not the user has the rights to send commands to clients.",
          "default": false
        },
        "policyRights": {
          "type": "boolean",
          "description": "Specifies whether or not the user has policy rights.",
          "default": false
        }
      }
    },
    "UserRole": {
      "type": "object",
      "required": [
        "bitMask",
        "title"
      ],
      "properties": {
        "bitMask": {
          "type": "integer",
          "format": "int32",
          "description": "The user role mask for the web user interface. Possible values are 8 for system administrator, 4 for domain administrator, and 2 for limited administrator."
        },
