          "401": {
            "description": "The user that is currently logged on has insufficient rights to execute the web method, or the user is unauthorized."
          },
          "409": {
            "description": "The request could not be completed due to a conflict with the current state of the source or target group."
          },
          "410": {
            "description": "Cannot find the specified object."
          },
          "500": {
            "description": "The web service encountered an error while processing the web request."
          }
        },
        "summary": "checks and moves a client to the specified group. A system administrator account is required for this REST API.",
        "tags": [
          "production"
        ]
      }
    },
