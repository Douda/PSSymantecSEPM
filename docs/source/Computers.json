  "host": "",
  "info": {
    "description": "This page documents the REST APIs that perform Symantec Endpoint Protection Manager operations.",
    "title": "Symantec Endpoint Protection Manager API Reference",
    "version": "v1"
  },
  "paths": {
    "/api/v1/computers": {
      "get": {
        "description": "",
        "operationId": "Get Computers",
        "parameters": [
          {
            "name": "computerName",
            "in": "query",
            "description": "The host name of computer. Wild card is supported as '*'.",
            "required": false,
            "type": "string"
          },
          {
            "name": "computer_id",
            "in": "query",
            "description": "The computer GUID. When computer_id is used the query will ignore all other query conditions except \"domain\", \"feature\" and \"verbose\" and return the current active one record.",
            "required": false,
            "type": "string"
          },
          {
            "name": "domain",
            "in": "query",
            "description": "The domain from which to get computer information.",
            "required": false,
            "type": "string"
          },
          {
            "name": "feature",
            "in": "query",
            "description": "List of features to return opstate information in reduced mode.Possible values are av, mem, fw, ips, tdad",
            "required": false,
            "type": "array",
            "items": {
              "type": "string"
            },
            "collectionFormat": "multi"
          },
          {
            "name": "hardware_key",
            "in": "query",
            "description": "The computer hardware key. When hardware_key is used and computer_id is empty the query will ignore all other query conditions except \"domain\", \"feature\" and \"verbose\" and return the current active one record.",
            "required": false,
            "type": "string"
          },
          {
            "name": "lastUpdate",
            "in": "query",
            "description": "Indicates when a computer last updated its status. The default value of 0 gets all the results.",
            "required": false,
            "type": "integer",
            "format": "int64"
          },
          {
            "name": "mac",
            "in": "query",
            "description": "The MAC address of computer. Wild card is supported as '*'.",
            "required": false,
            "type": "string"
          },
          {
            "name": "order",
            "in": "query",
            "description": "Specifies whether the results are in ascending order (ASC) or descending order (DESC).",
            "required": false,
            "type": "string"
          },
          {
            "name": "os",
            "in": "query",
            "description": "The list of OS to filter. Possible values are CentOs, Debian, Fedora, MacOSX, Oracle, OSX, RedHat, SUSE, Ubuntu, Win10, Win2K, Win7, Win8, Win81, WinEmb7, WinEmb8, WinEmb81, WinFundamental, WinNT, Win2K3, Win2K8, Win2K8R2, Win2K12, Win2K12R2, Win2K16, WinVista, WinXP, WinXPEmb, WinXPProf64",
            "required": false,
            "type": "array",
            "items": {
              "enum": [
                "CentOs",
                "Debian",
                "Fedora",
                "MacOSX",
                "Oracle",
                "OSX",
                "RedHat",
                "SUSE",
                "Ubuntu",
                "Win10",
                "Win11",
                "Win2K",
                "Win7",
                "Win8",
                "Win81",
                "WinEmb7",
                "WinEmb8",
                "WinEmb81",
                "WinFundamental",
                "WinNT",
                "Win2K3",
                "Win2K8",
                "Win2K8R2",
                "Win2K12",
                "Win2K12R2",
                "Win2K16",
                "Win2K19",
                "Win2K22",
                "WinVista",
                "WinXP",
                "WinXPEmb",
                "WinXPProf64"
              ],
              "type": "string"
            },
            "collectionFormat": "multi"
          },
          {
            "name": "pageIndex",
            "in": "query",
            "description": "The index page used for returned results. The default page index is 1.",
            "required": false,
            "type": "integer",
            "format": "int32"
          },
          {
            "name": "pageSize",
            "in": "query",
            "description": "The number of results to include on each page. The default is 20.",
            "required": false,
            "type": "integer",
            "format": "int32"
          },
          {
            "name": "sort",
            "in": "query",
            "description": "The column by which the results are sorted. Possible values are COMPUTER_NAME (Default value), COMPUTER_ID, COMPUTER_DOMAIN_NAME, or DOMAIN_ID.",
            "required": false,
            "type": "string"
          },
          {
            "name": "verbose",
            "in": "query",
            "description": "Returns a reduced set of computer information if true.",
            "required": false,
            "type": "boolean"
          }
        ],
        "responses": {
          "200": {
            "description": "The web service successfully processed the web request and returned a result.",
            "schema": {
              "$ref": "#/definitions/PageObject"
            }
          },
          "400": {
            "description": "The parameters are invalid."
          },
          "401": {
            "description": "The user that is currently logged on has insufficient rights to execute the web method, or the user is unauthorized."
          },
          "404": {
            "description": "The requested resource was not found."
          },
          "500": {
            "description": "The web service encountered an error while processing the web request."
          }
        },
        "summary": "Gets the information about the computers in a specified domain. A system administrator account is required for this REST API.",
        "tags": [
          "production"
        ]
      },
      "patch": {
        "description": "",
        "operationId": "Move Clients",
        "parameters": [
          {
