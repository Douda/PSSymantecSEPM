            "$ref": "#/definitions/ExceptionsRuleMacFile"
          },
          "type": "array"
        }
      }
    },
    "ExceptionsRuleApplication": {
      "type": "object",
      "required": [
        "processfile"
      ],
      "properties": {
        "action": {
          "description": "The action of the threat in exceptions policy.",
          "enum": [
            "IGNORE",
            "LOG_ONLY",
            "QUARANTINE",
            "BLOCK"
          ],
          "type": "string"
        },
        "deleted": {
          "description": "Note if the rule need be deleted when we PATCH a request",
          "type": "boolean"
        },
        "processfile": {
          "$ref": "#/definitions/ExceptionsFile",
          "description": "The process to ignore"
        },
        "rulestate": {
          "$ref": "#/definitions/ExceptionsRuleState",
          "description": "Rule options"
        }
      }
    },
    "ExceptionsRuleBlacklist": {
      "type": "object",
      "required": [
        "action",
        "processfile"
      ],
      "properties": {
        "action": {
          "description": "Action to take on the process",
          "enum": [
            "BLOCK",
            "QUARANTINE",
            "REMOVE"
          ],
          "type": "string"
        },
        "deleted": {
          "description": "Note if the rule need be deleted when we PATCH a request",
          "type": "boolean"
        },
        "processfile": {
          "$ref": "#/definitions/ExceptionsFile",
          "description": "The process to block, delete or quarantine"
        },
        "rulestate": {
          "$ref": "#/definitions/ExceptionsRuleState",
          "description": "Rule options"
        }
      }
    },
    "ExceptionsRuleCertificate": {
      "type": "object",
      "required": [
        "signature_fingerprint"
      ],
      "properties": {
        "deleted": {
          "description": "Note if the rule need be deleted when we PATCH a request",
          "type": "boolean"
        },
        "rulestate": {
          "$ref": "#/definitions/ExceptionsRuleState",
          "description": "Rule options"
        },
        "signature_company_name": {
          "description": "The company name on the certificate",
          "type": "string"
        },
        "signature_fingerprint": {
          "$ref": "#/definitions/ExceptionsFingerprint",
          "description": "Hash of the digital certificate"
        },
        "signature_fingerprints": {
          "description": "List of hash of the digital certificates [Only supported with V2 APIs]. If SHA1 is provided here, `signature_fingerprint`'s value will be ignored",
          "items": {
            "$ref": "#/definitions/ExceptionsFingerprint"
          },
          "type": "array"
        },
        "signature_issuer": {
          "description": "he issuer of the object signature",
          "type": "string"
        }
      }
    },
    "ExceptionsRuleDirectory": {
      "type": "object",
      "required": [
        "directory",
        "pathvariable"
      ],
      "properties": {
        "deleted": {
          "description": "Note if the rule need be deleted when we PATCH a request",
          "type": "boolean"
        },
        "directory": {
          "description": "Folder name",
          "type": "string"
        },
        "pathvariable": {
          "description": "A prefix variable indicates a well-known Windows folder",
          "enum": [
            "NONE",
            "COMMON_APPDATA",
            "COMMON_DESKTOPDIRECTORY",
            "COMMON_DOCUMENTS",
            "COMMON_PROGRAMS",
            "COMMON_STARTUP",
            "PROGRAM_FILES",
            "PROGRAM_FILES_COMMON",
            "SYSTEM",
            "SYSTEM_DRIVE",
            "USER_PROFILE",
            "WINDOWS"
          ],
          "type": "string"
        },
        "recursive": {
          "description": "Indicates whether sub-folders are also excluded",
          "type": "boolean"
        },
        "rulestate": {
          "$ref": "#/definitions/ExceptionsRuleState",
          "description": "Rule options"
        },
        "scancategory": {
          "description": "Type of security risk scan",
          "enum": [
            "GESC_AP",
            "GESC_MANUAL",
            "GESC_ALL"
          ],
          "type": "string"
        },
        "scantype": {
          "description": "Type of scan that exclude the folder",
          "enum": [
            "GEPT_RISK",
            "GEPT_SECURITY_RISK",
            "GEPT_HPP",
            "GEPT_ADC",
            "ALL"
          ],
          "type": "string"
        }
      }
    },
    "ExceptionsRuleDnsHostBlacklist": {
      "type": "object",
      "required": [
        "action",
        "processfile"
      ],
      "properties": {
        "action": {
          "description": "Action to take on the process",
          "enum": [
            "BLOCK",
            "PROMPT"
          ],
          "type": "string"
        },
        "deleted": {
          "description": "Note if the rule need be deleted when we PATCH a request",
          "type": "boolean"
        },
        "processfile": {
          "$ref": "#/definitions/ExceptionsFile",
          "description": "The process to block or prompt"
        },
        "rulestate": {
          "$ref": "#/definitions/ExceptionsRuleState",
          "description": "Rule options"
        }
