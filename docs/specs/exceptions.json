    "ExceptionsFile": {
      "type": "object",
      "required": [
        "sha2"
      ],
      "properties": {
        "company": {
          "description": "Optional attribute identifying the process.  The name of the company that published the object.",
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "directory": {
          "description": "Optional attribute identifying the process.  The directory where the object was originally found.",
          "type": "string"
        },
        "md5": {
          "pattern": "(^[0-9a-fA-F]{32}$)",
          "type": "string"
        },
        "name": {
          "description": "Optional attribute identifying the process.  The name of the file object; for example, iexplore.exe",
          "type": "string"
        },
        "sha2": {
          "description": "The SHA-256, SHA-1, or MD5 checksum of the object content.",
          "pattern": "(^[0-9a-fA-F]{64}$)|(^[0-9a-fA-F]{40}$)|(^[0-9a-fA-F]{32}$)",
          "type": "string"
        },
        "size": {
          "description": "Optional attribute identifying the process.  The size of the object, in bytes; for example, 69472.",
          "format": "int64",
          "maximum": 9223372036854776000,
          "minimum": 0,
          "type": "integer"
        }
      }
    },
    "ExceptionsFingerprint": {
      "type": "object",
      "required": [
        "algorithm",
        "value"
      ],
      "properties": {
        "algorithm": {
          "description": "The algorithm used to create the fingerprint.  SHA-1 support only for SAEPv1 for certificate thumbprint.",
          "enum": [
            "SHA1",
            "SHA2"
          ],
          "type": "string"
        },
        "value": {
          "description": "The hash of the object content.",
          "pattern": "^[0-9a-fA-F]*$",
          "type": "string"
        }
      }
    },
    "ExceptionsLinuxConfiguration": {
      "type": "object",
      "properties": {
        "directories": {
