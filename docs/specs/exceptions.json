        },
        "rulestate": {
          "$ref": "#/definitions/ExceptionsRuleState",
          "description": "Rule options"
        }
      }
    },
    "ExceptionsRuleExtensionList": {
      "type": "object",
      "required": [
        "extensions"
      ],
      "properties": {
        "deleted": {
          "description": "Note if the rule need be deleted when we PATCH a request",
          "type": "boolean"
        },
        "extensions": {
          "description": "The extensions.",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "rulestate": {
          "$ref": "#/definitions/ExceptionsRuleState",
          "description": "Rule options"
        },
        "scancategory": {
          "description": "The scan category.",
          "enum": [
            "GESC_AP",
            "GESC_MANUAL",
            "GESC_ALL"
          ],
          "type": "string"
        }
      }
    },
    "ExceptionsRuleFile": {
      "type": "object",
      "required": [
        "path",
        "pathvariable"
      ],
      "properties": {
        "SONAR": {
          "type": "boolean"
        },
        "applicationcontrol": {
          "description": "Exclude this file from application control",
          "type": "boolean"
        },
        "deleted": {
          "description": "Note if the rule need be deleted when we PATCH a request",
          "type": "boolean"
        },
        "path": {
          "description": "The path to the object.  Relative path if pathvariable is defined.  Full path if pathvariable is [NONE] or not specified",
          "type": "string"
        },
        "pathvariable": {
          "description": "A prefix variable indicates a well-known Windows folder",
          "enum": [
            "NONE",
            "COMMON_APPDATA",
            "COMMON_DESKTOPDIRECTORY",
            "COMMON_DOCUMENTS",
