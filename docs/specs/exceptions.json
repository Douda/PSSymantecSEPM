          },
          "type": "array"
        },
        "extension_list": {
          "$ref": "#/definitions/ExceptionsRuleExtensionList",
          "description": "Extension on Linux platforms at the exceptions policy"
        }
      }
    },
    "ExceptionsLockedOptions": {
      "type": "object",
      "properties": {
        "application": {
          "type": "boolean"
        },
        "certificate": {
          "type": "boolean"
        },
        "dnshostfile": {
          "type": "boolean"
        },
        "domain": {
          "type": "boolean"
        },
        "extension": {
          "type": "boolean"
        },
        "file": {
          "type": "boolean"
        },
        "knownrisk": {
          "type": "boolean"
        },
        "securityrisk": {
          "type": "boolean"
        },
        "sonar": {
          "type": "boolean"
        }
