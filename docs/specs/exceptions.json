        },
        "mac": {
          "$ref": "#/definitions/ExceptionsMacConfiguration",
          "description": "Mac files at the exceptions policy"
        },
        "non_pe_rules": {
          "items": {
            "$ref": "#/definitions/ExceptionsRuleNonPEFile"
          },
          "type": "array"
        },
        "tamper_files": {
          "description": "Tamper files at the exceptions policy",
