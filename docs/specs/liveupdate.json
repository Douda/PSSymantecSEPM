{
  "swagger": "2.0",
  "info": {
    "description": "This page documents the REST APIs that perform Symantec Endpoint Protection Manager operations.",
    "title": "Symantec Endpoint Protection Manager API Reference",
    "version": "v1"
  },
  "basePath": "/sepm/api/v1",
  "schemes": [
    "https"
  ],
  "paths": {
    "/api/v1/policies/lu/{id}": {
      "get": {
        "description": "",
        "operationId": "Get Policy",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "The ID of the LiveUpdate settings policy to get.",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "successful operation",
            "schema": {
              "$ref": "#/definitions/PolicyLuConfigurationObject"
            }
          }
        },
        "summary": "Get the LiveUpdate settings policy for specified policy id. A system administrator account is required for this REST API.",
        "tags": [
          "production"
        ]
      }
    }
  },
  "definitions": {
    "Advanced": {
      "type": "object",
      "properties": {
        "allow_download_smaller_package": {
          "description": "Allow client download smaller LU package",
          "type": "boolean"
        },
        "allow_manual_lu": {
          "description": "Allow running LU manually",
          "type": "boolean"
        },
        "allow_patch_by_lu": {
          "description": "Allow patch by LiveUpdate",
          "type": "boolean"
        },
        "allow_proxy_setting_change": {
          "description": "Allow local proxy setting change",
          "type": "boolean"
        },
        "allow_schedule_change": {
          "description": "Allow local schedule change",
          "type": "boolean"
        },
        "require_http_headers": {
          "description": "Require standard HTTP headers",
          "type": "boolean"
        }
      }
    },
    "CenteralLuServer": {
      "type": "object",
      "properties": {
        "description": {
          "description": "Description of the internal LU server",
          "type": "string"
        },
        "name": {
          "description": "Name of the internal LU server",
          "type": "string"
        },
        "password": {
          "description": "Password of the internal LU server",
          "type": "string"
        },
        "protocol": {
          "description": "Protocol of the internal LU server",
          "type": "string"
        },
        "url": {
          "description": "URL of the internal LU server",
          "type": "string"
        },
        "username": {
          "description": "Username of the internal LU server",
          "type": "string"
        }
      }
    },
    "FtpProxy": {
      "type": "object",
      "properties": {
        "ftp_proxy_option": {
          "description": "FTP proxy option",
          "enum": [
            "NO_PROXY",
            "CLIENT_BROWSER_SPECIFIED_PROXY",
            "CUSTOMIZED_PROXY"
          ],
          "type": "string"
        },
        "host": {
          "description": "host name of FTP proxy",
          "type": "string"
        },
        "port": {
          "description": "port of FTP proxy",
          "format": "int32",
          "minimum": 0,
          "type": "integer"
        }
      }
    },
    "HttpProxy": {
      "type": "object",
      "properties": {
        "auth_domain": {
          "description": "Domain of the proxy",
          "type": "string"
        },
        "auth_mode": {
          "description": "Authenticate mode of the proxy",
          "enum": [
            "BASIC_AUTH",
            "NT_LAN_MANAGED_AUTH"
          ],
          "type": "string"
        },
        "auth_password": {
          "description": "Password of the proxy",
          "type": "string"
        },
        "auth_user_name": {
          "description": "Username of the proxy",
          "type": "string"
        },
        "authenticate": {
          "description": "If the proxy needs authentication",
          "type": "boolean"
        },
        "host": {
          "description": "Host name of the proxy",
          "type": "string"
        },
        "http_port": {
          "description": "HTTP port of the proxy",
          "format": "int32",
          "minimum": 0,
          "type": "integer"
        },
        "http_proxy_option": {
          "description": "HTTP proxy option",
          "enum": [
            "NO_PROXY",
            "WINDOWS_INTERNET_OPTIONS_PROXY",
            "CUSTOMIZED_PROXY"
          ],
          "type": "string"
        },
        "https_port": {
          "description": "HTTPS port of the proxy",
          "format": "int32",
          "minimum": 0,
          "type": "integer"
        }
      }
    },
    "LuConfiguration": {
      "type": "object",
      "properties": {
        "linux": {
          "$ref": "#/definitions/Platform",
          "description": "Linux setting configuration in LiveUpdate setting policy"
        },
        "mac": {
          "$ref": "#/definitions/Platform",
          "description": "MAC setting configuration in LiveUpdate setting policy"
        },
        "windows": {
          "$ref": "#/definitions/Platform",
          "description": "windows setting configuration in LiveUpdate setting policy"
        }
      }
    },
    "LuSchedule": {
      "type": "object",
      "properties": {
        "av_def_age": {
          "description": "AV definition age of the schedule",
          "format": "int32",
          "type": "integer"
        },
        "av_def_check_enabled": {
          "description": "Enable AV definition check of the schedule",
          "type": "boolean"
        },
        "av_def_check_freq": {
          "description": "AV definition check frequency of the schedule",
          "type": "string"
        },
        "day": {
          "description": "Day configuration of the schedule",
          "enum": [
            "SUNDAY",
            "MONDAY",
            "TUESDAY",
            "WEDNESDAY",
            "THURSDAY",
            "FRIDAY",
            "SATURDAY"
          ],
          "type": "string"
        },
        "disconnection_check_duration": {
          "description": "Disconnection check duration of the schedule",
          "format": "int32",
          "type": "integer"
        },
        "disconnection_check_enabled": {
          "description": "Enable disconnection check of the schedule",
          "type": "boolean"
        },
        "disconnection_check_freq": {
          "description": "Disconnection check frequency of the schedule",
          "type": "string"
        },
        "download_interval": {
          "description": "Download interval of the schedule",
          "format": "int32",
          "type": "integer"
        },
        "frequency": {
          "description": "Frequency configuration of the schedule",
          "enum": [
            "CONTINUOUS",
            "HOURLY",
            "DAILY",
            "WEEKLY"
          ],
          "type": "string"
        },
        "idle_detection": {
          "description": "Idle detection of the schedule",
          "type": "boolean"
        },
        "randomize_window": {
          "description": "Randomized window of the schedule",
          "format": "int32",
          "type": "integer"
        },
        "retry_window": {
          "description": "Retry window of the schedule",
          "format": "int32",
          "type": "integer"
        },
        "start_hour": {
          "description": "Start hour of the schedule",
          "format": "int32",
          "type": "integer"
        },
        "start_minute": {
          "description": "Start minute of the schedule",
          "format": "int32",
          "type": "integer"
        },
        "start_time": {
          "description": "Start time of the schedule",
          "format": "int64",
          "type": "integer"
        }
      }
    },
    "LuServer": {
      "type": "object",
      "properties": {
        "activate_ftp_mode": {
          "description": "If FTP mode activated",
          "type": "boolean"
        },
        "central_lu_servers": {
          "description": "Central LU servers configuration",
          "items": {
            "$ref": "#/definitions/CenteralLuServer"
          },
          "type": "array"
        },
        "gup": {
          "$ref": "#/definitions/GroupUpdateProvider",
          "description": "Group update provider configuration"
        },
        "https_trusted": {
          "description": "if trusts HTTPS",
          "type": "boolean"
        },
        "proxy": {
          "$ref": "#/definitions/ProxyConfiguration",
          "description": "Proxy configuration"
        },
        "use_3rd_party_server": {
          "description": "if enable 3rd party LiveUpdate server",
          "type": "boolean"
        },
        "use_default_mgmt_server": {
          "description": "If uses default management server as LiveUpdate server",
          "type": "boolean"
        },
        "use_liveupdate_server": {
          "description": "If uses LiveUpdate server",
          "type": "boolean"
        }
      }
    },
    "PolicyLuConfigurationObject": {
      "type": "object",
      "required": [
        "name"
      ],
      "properties": {
        "configuration": {
          "$ref": "#/definitions/LuConfiguration",
          "description": "Configuration"
        },
        "desc": {
          "description": "The policy description.",
          "maxLength": 1024,
          "minLength": 1,
          "type": "string"
        },
        "enabled": {
          "description": "Indicates whether the policy is enabled or not.",
          "type": "boolean"
        },
        "lastmodifiedtime": {
          "format": "int64",
          "type": "integer"
        },
        "lockedoptions": {
          "description": "Option names to be locked",
          "type": "object"
        },
        "name": {
          "description": "The policy name.",
          "maxLength": 255,
          "minLength": 1,
          "pattern": "^[^/\\\\*?<>|:\"]*$",
          "type": "string"
        },
        "sources": {
          "description": "A list of data objects provided by the policy source, which includes the ID, the name and the version.",
          "items": {
            "$ref": "#/definitions/Sources"
          },
          "type": "array"
        }
      }
    },
    "WeekDays": {
      "type": "object",
      "properties": {
        "friday": {
          "description": "Enable upgrade on Friday.",
          "type": "boolean"
        },
        "monday": {
          "description": "Enable upgrade on Monday.",
          "type": "boolean"
        },
        "saturday": {
          "description": "Enable upgrade on Saturday.",
          "type": "boolean"
        },
        "sunday": {
          "description": "Enable upgrade on Sunday.",
          "type": "boolean"
        },
        "thursday": {
          "description": "Enable upgrade on Thursday.",
          "type": "boolean"
        },
        "time": {
          "description": "Start time of window where upgrades are permitted. Format is 0000-00-00TThh:mm:ss.sTZD",
          "type": "string"
        },
        "tuesday": {
          "description": "Enable upgrade on Tuesday.",
          "type": "boolean"
        },
        "wednesday": {
          "description": "Enable upgrade on Wednesday.",
          "type": "boolean"
        }
      }
    }
  }
}