{
  "swagger": "2.0",
  "info": {
    "description": "This page documents the REST APIs that perform Symantec Endpoint Protection Manager operations.",
    "title": "Symantec Endpoint Protection Manager API Reference",
    "version": "v1"
  },
  "basePath": "/sepm/api/v1",
  "schemes": [
    "https"
  ],
  "paths": {
    "/api/v1/policies/ips/{id}": {
      "get": {
        "description": "",
        "operationId": "Get Policy",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "The ID of the Ips policy to get.",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "successful operation",
            "schema": {
              "$ref": "#/definitions/PolicyIPSConfigurationObject"
            }
          }
        },
        "summary": "Get Ips Policy payload for specified policy id. A system administrator account is required for this REST API.",
        "tags": [
          "production"
        ]
      }
    }
  },
  "definitions": {
    "CustomGroupRule": {
      "type": "object",
      "properties": {
        "custom_ips_signatures": {
          "$ref": "#/definitions/CustomIPSSignatureRule"
        },
        "description": {
          "type": "string"
        },
        "enabled": {
          "type": "boolean"
        },
        "name": {
          "type": "string"
        }
      }
    },
    "CustomIPSSignatureRule": {
      "type": "object",
      "properties": {
        "action": {
          "enum": [
            "ALLOW",
            "BLOCK"
          ],
          "type": "string"
        },
        "applications": {
          "items": {
            "$ref": "#/definitions/File"
          },
          "type": "array"
        },
        "description": {
          "type": "string"
        },
        "enabled": {
          "type": "boolean"
        },
        "name": {
          "type": "string"
        },
        "packet_capture": {
          "type": "boolean"
        },
        "packet_direction_id": {
          "format": "int32",
          "maximum": 2,
          "minimum": 0,
          "type": "integer"
        },
        "severity": {
          "format": "int32",
          "type": "integer"
        },
        "traffic_condition": {
          "type": "string"
        }
      }
    },
    "CustomVariableRule": {
      "type": "object",
      "properties": {
        "content": {
          "type": "boolean"
        },
        "description": {
          "type": "string"
        },
        "enabled": {
          "type": "boolean"
        },
        "name": {
          "type": "string"
        }
      }
    },
    "IPSConfiguration": {
      "type": "object",
      "properties": {
        "browser_protection": {
          "enum": [
            "ALLOW",
            "BLOCK",
            "LOG"
          ],
          "type": "string"
        },
        "custom_ips_signature_groups": {
          "items": {
            "$ref": "#/definitions/CustomGroupRule"
          },
          "type": "array"
        },
        "custom_variables": {
          "items": {
            "$ref": "#/definitions/CustomVariableRule"
          },
          "type": "array"
        },
        "enabled": {
          "type": "boolean"
        },
        "endpoint_notification": {
          "$ref": "#/definitions/EndpointNotification"
        },
        "ips_signatures": {
          "items": {
            "$ref": "#/definitions/IPSSignatureRule"
          },
          "type": "array"
        },
        "mac": {
          "items": {
            "$ref": "#/definitions/IPSSignatureRule"
          },
          "type": "array"
        },
        "out_of_band": {
          "type": "boolean"
        },
        "server_signature_set": {
          "type": "boolean"
        },
        "url_reputation": {
          "type": "boolean"
        }
      }
    },
    "IPSRuleState": {
      "type": "object",
      "required": [
        "source"
      ],
      "properties": {
        "enabled": {
          "description": "Ability to disable a rule temporarily from enforcement without deleting it",
          "type": "boolean"
        },
        "newly_added": {
          "type": "boolean"
        },
        "source": {
          "description": "Which 3rd-party management system was the source of the rule; ex, SEP, ATP",
          "type": "string"
        }
      }
    },
    "IPSSignatureRule": {
      "type": "object",
      "properties": {
        "action": {
          "enum": [
            "ALLOW",
            "BLOCK"
          ],
          "type": "string"
        },
        "classifications": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "cve_uid": {
          "format": "int32",
          "type": "integer"
        },
        "id": {
          "format": "int32",
          "type": "integer"
        },
        "log_action": {
          "format": "int32",
          "type": "integer"
        },
        "name": {
          "type": "string"
        },
        "protection": {
          "enum": [
            "BROWSER",
            "IPS"
          ],
          "type": "string"
        },
        "rulestate": {
          "$ref": "#/definitions/IPSRuleState"
        },
        "server": {
          "type": "boolean"
        },
        "severity": {
          "format": "int32",
          "type": "integer"
        }
      }
    },
    "IpsAndHostsRule": {
      "type": "object",
      "properties": {
        "host_names": {
          "description": "Host names",
          "items": {
            "$ref": "#/definitions/HostNameData"
          },
          "type": "array"
        },
        "ip_addrs": {
          "description": "IP addresses",
          "items": {
            "$ref": "#/definitions/IpData"
          },
          "type": "array"
        }
      }
    },
    "PolicyIPSConfigurationObject": {
      "type": "object",
      "required": [
        "name"
      ],
      "properties": {
        "configuration": {
          "$ref": "#/definitions/IPSConfiguration",
          "description": "Configuration"
        },
        "desc": {
          "description": "The policy description.",
          "maxLength": 1024,
          "minLength": 1,
          "type": "string"
        },
        "enabled": {
          "description": "Indicates whether the policy is enabled or not.",
          "type": "boolean"
        },
        "lastmodifiedtime": {
          "format": "int64",
          "type": "integer"
        },
        "lockedoptions": {
          "description": "Option names to be locked",
          "type": "object"
        },
        "name": {
          "description": "The policy name.",
          "maxLength": 255,
          "minLength": 1,
          "pattern": "^[^/\\\\*?<>|:\"]*$",
          "type": "string"
        },
        "sources": {
          "description": "A list of data objects provided by the policy source, which includes the ID, the name and the version.",
          "items": {
            "$ref": "#/definitions/Sources"
          },
          "type": "array"
        }
      }
    }
  }
}