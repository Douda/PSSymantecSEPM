          },
          "500": {
            "description": "The web service encountered an error while processing the web request."
          }
        },
        "summary": "Gets the license configuration. A system administrator account is required for this REST API.",
        "tags": [
          "production"
        ]
      }
    },
    "/api/v1/licenses/entitlements": {
      "get": {
        "description": "",
        "operationId": "Get Entitlements",
        "parameters": [
          {
            "description": "Only used internally.",
            "in": "body",
            "name": "body",
            "required": false,
            "schema": {
              "$ref": "#/definitions/blacklist_HttpServletRequest"
            }
          },
          {
            "name": "serialNumbers",
            "in": "query",
            "description": "The serial numbers used to retrieve the licenses.",
            "required": true,
            "type": "array",
            "items": {
              "type": "string"
            },
            "collectionFormat": "multi"
          }
        ],
        "responses": {
          "200": {
            "description": "The web service successfully processed the web request and returned a result.",
            "schema": {
              "items": {
                "$ref": "#/definitions/LicenseSummaryDetails"
              },
              "type": "array"
            }
          },
          "400": {
            "description": "The parameters are invalid."
          },
          "401": {
            "description": "The user that is currently logged on has insufficient rights to execute the web method, or the user is unauthorized."
          },
          "404": {
            "description": "The requested resource was not found."
          },
          "500": {
            "description": "The web service encountered an error while processing the web request."
          }
        },
        "summary": "Retrieves specified licenses from the licensing server, given a list of serial numbers. A system administrator account is required for this REST API.",
        "tags": [
          "production"
        ]
      }
    },
    "/api/v1/licenses/summary": {
      "get": {
        "description": "",
        "operationId": "Get Sepm License Summary",
        "parameters": [
          {
            "name": "domainId",
            "in": "query",
            "required": false,
