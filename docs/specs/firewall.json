    "/api/v1/policies/firewall/{id}": {
      "get": {
        "description": "",
        "operationId": "Get Policy",
        "parameters": [
          {
            "description": "Only used internally.",
            "in": "body",
            "name": "body",
            "required": false,
            "schema": {
              "$ref": "#/definitions/HttpServletRequest"
            }
          },
          {
            "name": "id",
            "in": "path",
            "description": "The ID of the firewall policy to get.",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "successful operation",
            "schema": {
              "$ref": "#/definitions/PolicyFirewallConfigurationObject"
            }
          }
        },
        "summary": "Get the firewall policy for specified policy id. A system administrator account is required for this REST API.",
        "tags": [
          "production"
        ]
      },
      "delete": {
        "description": "",
        "operationId": "Delete Policy",
        "parameters": [
          {
            "description": "Only used internally.",
            "in": "body",
            "name": "body",
            "required": false,
            "schema": {
              "$ref": "#/definitions/HttpServletRequest"
            }
          },
          {
            "name": "id",
            "in": "path",
            "description": "The ID of the Firewall policy to delete.",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "204": {
            "description": ""
          }
        },
        "summary": "Deletes an existing Firewall policy. A system administrator account is required for this REST API.",
        "tags": [
          "production"
        ]
      }
    }
