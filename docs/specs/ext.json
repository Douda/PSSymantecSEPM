    "Group": {
      "type": "object",
      "required": [
        "name"
      ],
      "properties": {
        "id": {
          "type": "string",
          "description": "Group ID, this is set by SEPM, user can not set it"
        },
        "name": {
          "type": "string",
          "description": "Group name"
        },
        "description": {
          "type": "string",
          "description": "Group description if any"
        },
        "fullPathName": {
          "type": "string",
          "description": "Group full path from the root group, this is set by SEPM, user can not set it"
        },
        "numberOfPhysicalComputers": {
          "type": "integer",
          "format": "int32",
          "description": "The computer count in this group, this is set by SEPM, user can not set it"
        },
        "numberOfRegisteredUsers": {
          "type": "integer",
          "format": "int32",
          "description": "The user count in this group, this is set by SEPM, user can not set it"
        },
        "createdBy": {
          "type": "string",
          "description": "Admin's ID who created this group, this is set by SEPM, user can not set it"
        },
        "created": {
          "type": "integer",
          "format": "int64",
          "description": "When this group was created, this is set by SEPM, user can not set it"
        },
        "lastModified": {
          "type": "integer",
          "format": "int64",
          "description": "When this group was last modified, this is set by SEPM, user can not set it"
        },
        "policySerialNumber": {
          "type": "string",
          "description": "Group's policy serial number, this is set by SEPM, user can not set it"
        },
        "policyDate": {
          "type": "integer",
          "format": "int64"
        },
        "customIpsNumber": {
          "type": "string",
          "description": "Group's custom IPS policy number, it's not used for now"
        },
        "defaultLocationId": {
          "type": "string",
          "description": "Default Location Id for the group, if this group inherits from its parent, it's its non-inherit parent's default location."
        },
        "domain": {
          "description": "Domain which this group belongs to",
          "$ref": "#/definitions/DomainSummary"
        },
        "policyInheritanceEnabled": {
          "type": "boolean",
          "description": "Whether this group's policy is inheritated from its parent",
          "default": false
        },
        "childGroups": {
          "type": "array",
          "description": "Child groups"
        },
        "externalReferenceId": {
          "type": "string",
          "description": "External Referene Id for this group.",
          "minLength": 1,
          "maxLength": 50
        }
      }
    },
