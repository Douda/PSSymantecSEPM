    "/api/v1/ext/groups/syncdelete": {
      "post": {
        "tags": [
          "production"
        ],
        "summary": "Delete groups. A system administrator account is required for this REST API.",
        "description": "",
        "operationId": "Sync Delete Groups",
        "parameters": [
          {
            "name": "domainId",
            "in": "query",
            "description": "The id of the domain for which the groups needs to be deleted.",
            "required": false,
            "type": "string"
          },
          {
            "in": "body",
            "name": "body",
            "description": "Group details",
            "required": true,
            "schema": {
              "$ref": "#/definitions/Group"
            }
          }
        ],
        "responses": {
          "200": {
            "description": ""
          }
        }
      }
    },
    "/api/v1/ext/groups/synchronization": {
      "post": {
        "tags": [
          "production"
        ],
        "summary": "Add/Update groups. A system administrator account is required for this REST API.",
        "description": "",
        "operationId": "Sync Groups",
        "parameters": [
          {
            "name": "domainId",
            "in": "query",
            "description": "The id of the domain for which the groups needs to be created/updated.",
            "required": false,
            "type": "string"
          },
          {
            "in": "body",
            "name": "body",
            "description": "Group details",
            "required": true,
            "schema": {
              "$ref": "#/definitions/Group"
            }
          }
        ],
        "responses": {
          "200": {
            "description": ""
          }
        }
      },
      "delete": {
        "tags": [
          "production"
        ],
        "summary": "Changes the group node type back to its default value i.e Native for all the groups and temporary for default group and changes the external Reference Id back to null.",
        "description": "",
        "operationId": "Unsynchronize Groups",
        "parameters": [
          {
            "name": "domainId",
            "in": "query",
            "required": false,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": ""
          }
        }
      }
    },
    "/api/v1/ext/groups/{group_id}/policies/external-communication": {
      "get": {
        "tags": [
          "production"
        ],
        "summary": "Get cloud external communication settings for the given group",
        "description": "",
        "operationId": "Get Group Cloud External Communication Settings",
        "parameters": [
          {
            "name": "group_id",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": ""
          }
        }
      },
      "put": {
        "tags": [
          "production"
        ],
        "summary": "Update lowbandwidth external communication settings to a given group. The values that are not specified are set to defaults",
        "description": "",
        "operationId": "Update Group External Communication",
        "parameters": [
          {
            "name": "group_id",
            "in": "path",
            "description": "The ID of the group",
            "required": true,
            "type": "string"
          },
          {
            "in": "body",
            "name": "body",
            "description": "The Settings to be used.",
            "required": true,
            "schema": {
              "$ref": "#/definitions/SettingsExternalCommunicationSettingsObject"
            }
          },
          {
            "in": "body",
            "name": "body",
            "description": "Only used internally.",
            "required": false,
            "schema": {
              "$ref": "#/definitions/groups_HttpServletRequest"
            }
          }
        ],
        "responses": {
          "200": {
            "description": ""
          }
        }
      },
      "delete": {
        "tags": [
          "production"
        ],
        "summary": "Withdraw a cloud setting from a group.",
        "description": "",
        "operationId": "Withdraw Setting From Group",
        "parameters": [
          {
            "name": "group_id",
            "in": "path",
            "description": "The ID of the group from which the sepm setting needs to be withdrawn.",
            "required": true,
            "type": "string"
          },
          {
            "in": "body",
            "name": "body",
            "description": "Only used internally.",
            "required": false,
            "schema": {
              "$ref": "#/definitions/groups_HttpServletRequest"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "successful operation",
            "schema": {
              "type": "string"
            }
          },
          "204": {
            "description": "Delete operation success. If the resource did not exist prior to the call, 204 is still returned."
          },
          "400": {
            "description": "Invalid parameters"
          },
          "401": {
            "description": "The current logged in user does not have sufficient rights to execute the web method or user is unauthorized"
          },
          "404": {
            "description": "The resource reguested was not found"
          },
          "500": {
            "description": "The web service encountered an error processing the web request"
          }
        }
      }
    },
