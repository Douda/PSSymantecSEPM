{
  "swagger": "2.0",
  "info": {
    "description": "This page documents the REST APIs that perform Symantec Endpoint Protection Manager operations.",
    "title": "Symantec Endpoint Protection Manager API Reference",
    "version": "v1"
  },
  "basePath": "/sepm/api/v1",
  "schemes": [
    "https"
  ],
  "paths": {
    "/api/v1/policies/tdad": {
      "post": {
        "description": "",
        "operationId": "Create Policy",
        "parameters": [
          {
            "description": "The Threat Defense for Active Directory policy to be created.",
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/PolicyTdadConfigurationObject"
            }
          }
        ],
        "responses": {
          "201": {
            "description": ""
          }
        },
        "summary": "Creates a new Threat Defense for Active Directory policy. A system administrator account is required for this REST API.",
        "tags": [
          "production"
        ]
      }
    },
    "/api/v1/policies/tdad/{id}": {
      "get": {
        "description": "",
        "operationId": "Get Policy",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "The ID of the TDAD policy to get.",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "successful operation",
            "schema": {
              "$ref": "#/definitions/PolicyTdadConfigurationObject"
            }
          }
        },
        "summary": "Get TDAD Policy payload for specified policy id. A system administrator account is required for this REST API.",
        "tags": [
          "production"
        ]
      },
      "put": {
        "description": "",
        "operationId": "Edit Policy",
        "parameters": [
          {
            "description": "The Threat Defense for Active Directory policy to be modified.",
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/PolicyTdadConfigurationObject"
            }
          },
          {
            "name": "id",
            "in": "path",
            "description": "The ID of the TDAD policy to edit.",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "successful operation",
            "schema": {
              "type": "string"
            }
          }
        },
        "summary": "Modify existing policy values. A system administrator account is required for this REST API.",
        "tags": [
          "production"
        ]
      },
      "delete": {
        "description": "",
        "operationId": "Delete Policy",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "The ID of the TDAD policy to delete.",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "204": {
            "description": ""
          }
        },
        "summary": "Deletes an existing TDAD policy. A system administrator account is required for this REST API.",
        "tags": [
          "production"
        ]
      },
      "patch": {
        "description": "",
        "operationId": "Update Policy",
        "parameters": [
          {
            "description": "The Threat Defense for Active Directory policy to be modified.",
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/PolicyTdadConfigurationObject"
            }
          },
          {
            "name": "id",
            "in": "path",
            "description": "The ID of the TDAD policy to update.",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "successful operation",
            "schema": {
              "type": "string"
            }
          }
        },
        "summary": "Update policies by patch. A system administrator account is required for this REST API.",
        "tags": [
          "production"
        ]
      }
    }
  },
  "definitions": {
    "PolicyTdadConfigurationObject": {
      "type": "object",
      "required": [
        "name"
      ],
      "properties": {
        "configuration": {
          "$ref": "#/definitions/TdadConfiguration",
          "description": "Configuration"
        },
        "desc": {
          "description": "The policy description.",
          "maxLength": 1024,
          "minLength": 1,
          "type": "string"
        },
        "enabled": {
          "description": "Indicates whether the policy is enabled or not.",
          "type": "boolean"
        },
        "lastmodifiedtime": {
          "format": "int64",
          "type": "integer"
        },
        "lockedoptions": {
          "description": "Option names to be locked",
          "type": "object"
        },
        "name": {
          "description": "The policy name.",
          "maxLength": 255,
          "minLength": 1,
          "pattern": "^[^/\\\\*?<>|:\"]*$",
          "type": "string"
        },
        "sources": {
          "description": "A list of data objects provided by the policy source, which includes the ID, the name and the version.",
          "items": {
            "$ref": "#/definitions/Sources"
          },
          "type": "array"
        }
      }
    },
    "TdadConfiguration": {
      "type": "object",
      "properties": {
        "ad_domains": {
          "items": {
            "$ref": "#/definitions/TdadElement"
          },
          "type": "array"
        },
        "enabled": {
          "type": "boolean"
        }
      }
    },
    "TdadElement": {
      "type": "object",
      "properties": {
        "ad_domain_uid": {
          "type": "string"
        },
        "domain_name": {
          "type": "string"
        },
        "policy_uid": {
          "type": "string"
        },
        "policy_version": {
          "type": "string"
        },
        "sid": {
          "type": "string"
        }
      }
    }
  }
}