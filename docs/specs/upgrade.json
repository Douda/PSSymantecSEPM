{
  "swagger": "2.0",
  "info": {
    "description": "This page documents the REST APIs that perform Symantec Endpoint Protection Manager operations.",
    "title": "Symantec Endpoint Protection Manager API Reference",
    "version": "v1"
  },
  "basePath": "/sepm/api/v1",
  "schemes": [
    "https"
  ],
  "paths": {
    "/api/v1/policies/upgrade": {
      "post": {
        "description": "",
        "operationId": "Create Policy",
        "parameters": [
          {
            "description": "The upgrade policy to be created.",
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/PolicyUpgradeConfigurationObject"
            }
          }
        ],
        "responses": {
          "201": {
            "description": ""
          }
        },
        "summary": "Creates a new Upgrade policy. A system administrator account is required for this REST API.",
        "tags": [
          "production"
        ]
      }
    },
    "/api/v1/policies/upgrade/{id}": {
      "get": {
        "description": "",
        "operationId": "Get Policy",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "The ID of the Upgrade policy to get.",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "successful operation",
            "schema": {
              "$ref": "#/definitions/PolicyUpgradeConfigurationObject"
            }
          }
        },
        "summary": "Get Upgrade Policy payload for specified policy id. A system administrator account is required for this REST API.",
        "tags": [
          "production"
        ]
      },
      "put": {
        "description": "",
        "operationId": "Edit Policy",
        "parameters": [
          {
            "description": "The Upgrade policy to be modified.",
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/PolicyUpgradeConfigurationObject"
            }
          },
          {
            "name": "id",
            "in": "path",
            "description": "The ID of the Upgrade policy to edit.",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "successful operation",
            "schema": {
              "type": "string"
            }
          }
        },
        "summary": "Modify existing policy values. A system administrator account is required for this REST API.",
        "tags": [
          "production"
        ]
      },
      "delete": {
        "description": "",
        "operationId": "Delete Policy",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "The ID of the Upgrade policy to delete.",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "204": {
            "description": ""
          }
        },
        "summary": "Deletes an existing Upgrade policy. A system administrator account is required for this REST API.",
        "tags": [
          "production"
        ]
      },
      "patch": {
        "description": "",
        "operationId": "Update Policy",
        "parameters": [
          {
            "description": "The High Intensity Detection policy to be modified.",
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/PolicyUpgradeConfigurationObject"
            }
          },
          {
            "name": "id",
            "in": "path",
            "description": "The ID of the Upgrade policy to update.",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "successful operation",
            "schema": {
              "type": "string"
            }
          }
        },
        "summary": "Update policies by patch. A system administrator account is required for this REST API.",
        "tags": [
          "production"
        ]
      }
    }
  },
  "definitions": {
    "PolicyUpgradeConfigurationObject": {
      "type": "object",
      "required": [
        "name"
      ],
      "properties": {
        "configuration": {
          "$ref": "#/definitions/UpgradeConfiguration",
          "description": "Configuration"
        },
        "desc": {
          "description": "The policy description.",
          "maxLength": 1024,
          "minLength": 1,
          "type": "string"
        },
        "enabled": {
          "description": "Indicates whether the policy is enabled or not.",
          "type": "boolean"
        },
        "lastmodifiedtime": {
          "format": "int64",
          "type": "integer"
        },
        "lockedoptions": {
          "description": "Option names to be locked",
          "type": "object"
        },
        "name": {
          "description": "The policy name.",
          "maxLength": 255,
          "minLength": 1,
          "pattern": "^[^/\\\\*?<>|:\"]*$",
          "type": "string"
        },
        "sources": {
          "description": "A list of data objects provided by the policy source, which includes the ID, the name and the version.",
          "items": {
            "$ref": "#/definitions/Sources"
          },
          "type": "array"
        }
      }
    },
    "UpgradeConfiguration": {
      "type": "object",
      "properties": {
        "release_delay_days": {
          "description": "Number of days to wait to upgrade after SEPM publishes a release.",
          "format": "int32",
          "maximum": 45,
          "minimum": 0,
          "type": "integer"
        },
        "schedule": {
          "$ref": "#/definitions/UpgradeSchedule",
          "description": "Permissible days and time on which to upgrade."
        }
      }
    },
    "UpgradeSchedule": {
      "type": "object",
      "properties": {
        "daily": {
          "$ref": "#/definitions/WeekDays",
          "description": "The days to do the upgrade."
        },
        "end_time": {
          "description": "End time of window where upgrades are permitted. Format is 0000-00-00TThh:mm:ss.sTZD",
          "type": "string"
        },
        "retry_enabled": {
          "description": "Enable retries if client missed upgrade.",
          "type": "boolean"
        },
        "time_window": {
          "description": "Number of seconds in the distribution window. The client picks a random time within the window for its own upgrade.",
          "format": "int32",
          "maximum": 2592000,
          "minimum": 0,
          "type": "integer"
        }
      }
    }
  }
}