  "definitions": {
    "AddAdminEntry": {
      "type": "object",
      "required": [
        "adminType",
        "authenticationMethod",
        "emailAddress",
        "lockTimeThreshold",
        "loginAttemptThreshold",
        "loginName",
        "password"
      ],
      "properties": {
        "adminType": {
          "description": "The type of administrator. Possible values are 1 for system administrator, 2 for domain administrator, and 3 for limited administrator.",
          "format": "int32",
          "maximum": 3,
          "minimum": 1,
          "type": "integer"
        },
        "authenticationMethod": {
          "description": "The administrator's authentication method. Possible values are 0 for Symantec Endpoint Protection Manager Authentication, 1 for RSA SecurID Authentication, and 2 for Directory Authentication.",
          "format": "int32",
          "maximum": 2,
          "minimum": 0,
          "type": "integer"
        },
        "emailAddress": {
          "description": "The administrator's email address.",
          "type": "string"
        },
        "fullName": {
          "description": "The administrator's full name.",
          "maxLength": 50,
          "minLength": 0,
          "pattern": "^[^\"%<>&/\u0000-\u001f]+$",
          "type": "string"
        },
        "id": {
          "description": "The administrator's ID.",
          "type": "string"
        },
        "isReportingRights": {
          "type": "boolean"
        },
        "lockAccount": {
          "description": "Whether the administrator's account is configured to lock after a specified number of logon failures.",
          "type": "boolean"
        },
        "lockTimeThreshold": {
          "description": "The amount of time the administrator's account is locked after a logon failure.",
          "format": "int32",
          "maximum": 60,
          "minimum": 1,
          "type": "integer"
        },
        "loginAttemptThreshold": {
          "description": "The number of logon failures allowed before the administrator's account is locked.",
          "format": "int32",
          "maximum": 10,
          "minimum": 1,
          "type": "integer"
        },
        "loginName": {
          "description": "The administrator's logon name.",
          "maxLength": 64,
          "minLength": 1,
          "pattern": "^[^\"\\\\/\\[\\]:;|=,\\+\\*?<>\\s]+$",
          "type": "string"
        },
        "notifyAdminOfLockedState": {
          "description": "Whether to notify the administrator that the account is locked due to logon failures.",
          "type": "boolean"
        },
        "password": {
          "description": "The administrator's password.",
          "maxLength": 1024,
          "minLength": 8,
          "type": "string"
        },
        "reportingRights": {
          "description": "The administrator's reporting rights. Not currently used.",
          "type": "boolean"
        }
      }
    },
    "AdminEntry": {
      "type": "object",
      "required": [
        "emailAddress",
        "lockTimeThreshold",
        "loginAttemptThreshold"
      ],
      "properties": {
        "emailAddress": {
          "description": "The administrator's email address.",
          "type": "string"
        },
        "fullName": {
          "description": "The administrator's full name.",
          "maxLength": 50,
          "minLength": 0,
          "pattern": "^[^\"%<>&/\u0000-\u001f]+$",
          "type": "string"
        },
        "lockAccount": {
          "description": "Whether the administrator's account is configured to lock after a specified number of logon failures.",
          "type": "boolean"
        },
        "lockTimeThreshold": {
          "description": "The amount of time the administrator's account is locked after a logon failure.",
          "format": "int32",
          "maximum": 60,
          "minimum": 1,
          "type": "integer"
        },
        "loginAttemptThreshold": {
          "description": "The number of logon failures allowed before the administrator's account is locked.",
          "format": "int32",
          "maximum": 10,
          "minimum": 1,
          "type": "integer"
        },
        "notifyAdminOfLockedState": {
          "description": "Whether to notify the administrator that the account is locked due to logon failures.",
          "type": "boolean"
        }
      }
    },
    "AdminSummaryDetails": {
      "type": "object",
      "required": [
        "adminType",
        "attemptThreshold",
        "authenticationMethod",
        "companyName",
        "creationTime",
        "email",
        "enabled",
        "failedLoginCount",
        "lastLoginTime",
        "lastLogonIP",
        "lastPasswordChanged",
        "lockStatus",
        "lockTimeThreshold",
        "loginName",
        "onlineStatus",
        "passwordExpiresIn"
      ],
      "properties": {
        "adminType": {
          "description": "The type of administrator. Possible values are 1 for system administrator, 2 for domain administrator, and 3 for limited administrator.",
          "format": "int32",
          "type": "integer"
        },
        "attemptThreshold": {
          "description": "The number of logon failures allowed before the administrator's account is locked.",
          "type": "string"
        },
        "authenticationMethod": {
          "description": "The administrator's authentication method. Possible values are 0 for Symantec Endpoint Protection Manager Authentication, 1 for RSA SecurID Authentication, and 2 for Directory Authentication.",
          "format": "int32",
          "type": "integer"
        },
        "companyName": {
          "description": "The administrator's company name.",
          "type": "string"
        },
        "creationTime": {
          "description": "When the administrator account was created.",
          "format": "int64",
          "type": "integer"
        },
        "email": {
          "description": "The administrator's email address.",
          "type": "string"
        },
        "enabled": {
          "description": "Whether the administrator is enabled or not.",
          "type": "boolean"
        },
        "failedLoginCount": {
          "description": "The number of times the administrator's logon has failed.",
          "format": "int32",
          "type": "integer"
        },
        "fullName": {
          "description": "The administrator's full name.",
          "type": "string"
        },
        "id": {
          "description": "The administrator's ID.",
          "type": "string"
        },
        "lastLoginTime": {
          "description": "The administrator's last logon time.",
          "format": "int64",
          "type": "integer"
        },
        "lastLogonIP": {
          "description": "The administrator's last logon IP address.",
          "type": "string"
        },
        "lastPasswordChanged": {
          "description": "When the administrator's password was last changed.",
          "format": "int64",
          "type": "integer"
        },
        "lockAccount": {
          "description": "Whether the administrator's account is configured to lock after a specified number of logon failures.",
          "type": "boolean"
        },
        "lockStatus": {
          "description": "Whether the administrator is locked or not.",
          "type": "boolean"
        },
        "lockTimeThreshold": {
          "description": "The amount of time the administrator's account is locked after a logon failure.",
          "format": "int32",
          "type": "integer"
        },
        "loginName": {
          "description": "The administrator's logon name.",
          "type": "string"
        },
        "notifyAdminOfLockedState": {
          "description": "Whether to notify the administrator that the account is locked due to logon failures.",
          "type": "boolean"
        },
        "onlineStatus": {
          "description": "Whether the administrator is online or offline.",
          "type": "boolean"
        },
        "passwordExpiresIn": {
          "description": "When the administrator's password expires.",
          "format": "int64",
          "type": "integer"
        }
      }
