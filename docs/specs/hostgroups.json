        {
          "$ref": "#/definitions/Host"
        },
        {
          "type": "object",
          "required": [
            "dns_host"
          ],
          "properties": {
            "dns_host": {
              "description": "DNS host name of the host.",
              "type": "string"
            }
          }
        }
      ]
    },
    "DnsName": {
      "allOf": [
        {
          "$ref": "#/definitions/Host"
        },
        {
          "type": "object",
          "required": [
            "dns_domain"
          ],
          "properties": {
            "dns_domain": {
              "description": "DNS domain name of the host.",
              "type": "string"
            }
          }
        }
      ]
    },
    "ExceptionsMacConfiguration": {
      "type": "object",
      "properties": {
        "files": {
          "description": "Files on mac platforms at the exceptions policy",
          "items": {
            "$ref": "#/definitions/ExceptionsRuleMacFile"
          },
          "type": "array"
        }
      }
    },
    "ExceptionsRuleDnsHostBlacklist": {
      "type": "object",
      "required": [
        "action",
        "processfile"
      ],
      "properties": {
        "action": {
          "description": "Action to take on the process",
          "enum": [
            "BLOCK",
            "PROMPT"
          ],
          "type": "string"
        },
        "deleted": {
          "description": "Note if the rule need be deleted when we PATCH a request",
          "type": "boolean"
        },
        "processfile": {
          "$ref": "#/definitions/ExceptionsFile",
          "description": "The process to block or prompt"
        },
        "rulestate": {
          "$ref": "#/definitions/ExceptionsRuleState",
          "description": "Rule options"
        }
      }
    },
    "ExceptionsRuleMacFile": {
      "type": "object",
      "required": [
        "path",
        "pathvariable"
      ],
      "properties": {
        "deleted": {
          "description": "Note if the rule need be deleted when we PATCH a request",
          "type": "boolean"
        },
        "path": {
          "description": "The path to the object.  Relative path if pathvariable is defined.  Full path if pathvariable is [NONE] or not specified",
          "type": "string"
        },
        "pathvariable": {
          "description": "A prefix variable indicates a well-known Mac folder",
          "enum": [
            "NONE",
            "HOME",
            "APPLICATION",
            "LIBRARY"
          ],
          "type": "string"
        },
        "rulestate": {
          "$ref": "#/definitions/ExceptionsRuleState",
          "description": "Rule options"
        }
      }
    },
    "Host": {
      "type": "object"
    },
    "HostConfiguration": {
      "type": "object",
      "properties": {
        "dns_domain": {
          "type": "string"
        },
        "dns_host": {
          "type": "string"
        },
        "group_name": {
          "type": "string"
        },
        "group_uid": {
          "type": "string"
        },
        "ip": {
          "type": "string"
        },
        "ip_range": {
          "$ref": "#/definitions/IpRangeConfiguration"
        },
        "ipv4_subnet": {
          "$ref": "#/definitions/IPv4Subnet"
        },
        "ipv6_subnet": {
          "type": "string"
        },
        "local_subnet": {
          "type": "boolean"
        },
        "location": {
          "enum": [
            "LOCAL",
            "REMOTE",
            "SRC",
            "DST"
          ],
          "type": "string"
        },
        "mac": {
          "type": "string"
        }
      }
    },
    "HostGroup": {
      "type": "object",
      "required": [
        "hosts",
        "name"
      ],
      "properties": {
        "hosts": {
          "description": "The hosts of the host group policy component. The host is any of Mac, IpV4, IpV6, IpV4Range, IpV6Range, DnsName, DnsHost, IpV4Subnet, IpV6Subnet",
          "example": "{\n  \"name\": \"test-host\",\n  \"hosts\": [\n    {\"mac\": \"00-01-00-00-00-00\"},\n    {\"dns_domain\": \"*.test.com\"},\n    {\"dns_host\": \"aHostName\"},\n    {\"ip\": \"1.2.3.4\"},\n    {\"ipv4_subnet\": {\n      \"ip\": \"1.1.1.1\",\n      \"mask\": \"255.255.255.0\"\n    }},\n    {\"ipv4_range\": {\"ip_start\": \"1.2.3.4\", \"ip_end\": \"1.2.3.4\"}},\t\n    {\"ipv6\": \"2001:DB8:3C0:FC01:49C8:C72A::10\"},\n    {\"ipv6_subnet\": \"2002:C058:6301::/48\"},\n    {\"ipv6_range\": {\"ip_start\": \"2001:DB8:3C0:FC01:49C8:C72A::20\", \"ip_end\": \"2001:DB8:3C0:FC01:49C8:C72A::21\"}}\n  ]\n}",
          "items": {
            "$ref": "#/definitions/Host"
          },
          "type": "array"
        },
        "name": {
          "description": "Name of host group policy component.",
          "maxLength": 255,
          "minLength": 1,
          "pattern": "^[^/\\\\*?<>|:\"]*$",
          "type": "string"
        }
      }
    },
    "HostGroupSummary": {
      "type": "object",
      "required": [
        "name"
      ],
      "properties": {
        "domainid": {
          "type": "string"
        },
        "id": {
          "type": "string"
        },
        "lastmodifiedtime": {
          "format": "int64",
          "type": "integer"
        },
        "name": {
          "description": "The host group name.",
          "type": "string"
        }
      }
    },
    "HostNameData": {
      "type": "object",
      "properties": {
