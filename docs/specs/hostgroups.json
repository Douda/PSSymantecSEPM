    "Mac": {
      "allOf": [
        {
          "$ref": "#/definitions/Host"
        },
        {
          "type": "object",
          "required": [
            "mac"
          ],
          "properties": {
            "mac": {
              "description": "Mac address of the host.",
              "pattern": "^(?:[0-9A-Fa-f]{2}[-]){5}(?:[0-9A-Fa-f]{2})$",
              "type": "string"
            }
          }
        }
      ]
    },
