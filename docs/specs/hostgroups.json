    "IpRange": {
      "type": "object",
      "required": [
        "ip_end",
        "ip_start"
      ],
      "properties": {
        "ip_end": {
          "description": "End IP address of the range.",
          "type": "string"
        },
        "ip_start": {
          "description": "Star IP address of the range.",
          "type": "string"
        }
      }
    },
    "IpRangeConfiguration": {
      "type": "object",
      "properties": {
