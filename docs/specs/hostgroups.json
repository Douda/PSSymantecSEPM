{
  "swagger": "2.0",
  "info": {
    "description": "This page documents the REST APIs that perform Symantec Endpoint Protection Manager operations.",
    "title": "Symantec Endpoint Protection Manager API Reference",
    "version": "v1"
  },
  "basePath": "/sepm/api/v1",
  "schemes": [
    "https"
  ],
  "paths": {
    "/api/v1/policies/policy-objects/hostgroups": {
      "post": {
        "description": "",
        "operationId": "Create Policy",
        "parameters": [
          {
            "description": "The host group policy component to be created.",
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/HostGroup"
            }
          }
        ],
        "responses": {
          "201": {
            "description": ""
          }
        },
        "summary": "Create a new Host Group Policy Component.A system administrator account is required for this REST API.",
        "tags": [
          "production"
        ]
      }
    },
    "/api/v1/policies/policy-objects/hostgroups/summary": {
      "get": {
        "description": "",
        "operationId": "Get Host Group Summary",
        "parameters": [
          {
            "name": "domainId",
            "in": "query",
            "description": "If present, get host groups from this domain. Else get host groups from logged in domain.",
            "required": false,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "The web service successfully processed the web request and returned a result.",
            "schema": {
              "$ref": "#/definitions/PageHostGroupSummary"
            }
          },
          "400": {
            "description": "The parameters are invalid."
          },
          "401": {
            "description": "The user that is currently logged on has insufficient rights to execute the web method, or the user is unauthorized."
          },
          "404": {
            "description": "The requested resource was not found."
          },
          "410": {
            "description": "Can not find the object specified"
          },
          "500": {
            "description": "The web service encountered an error while processing the web request."
          }
        },
        "summary": "Get the host groups summary.",
        "tags": [
          "production"
        ]
      }
    },
    "/api/v1/policies/policy-objects/hostgroups/{id}": {
      "get": {
        "description": "",
        "operationId": "Get Host Group Policy",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "ID of the host group policy",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "successful operation",
            "schema": {
              "$ref": "#/definitions/HostGroup"
            }
          }
        },
        "summary": "Get host group policy",
        "tags": [
          "production"
        ]
      },
      "put": {
        "description": "",
        "operationId": "Update Policy",
        "parameters": [
          {
            "description": "The host group policy component to be updated.",
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/HostGroup"
            }
          },
          {
            "name": "id",
            "in": "path",
            "description": "The ID of the host group policy component to updated.",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": ""
          }
        },
        "summary": "Update a Host Group Policy Component. A system administrator account is required for this REST API.",
        "tags": [
          "production"
        ]
      }
    }
  },
  "definitions": {
    "DnsHost": {
