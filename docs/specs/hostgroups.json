        {
          "type": "object",
          "required": [
            "ip"
          ],
          "properties": {
            "ip": {
              "description": "IP v4 address of the host.",
              "pattern": "^(([0-9]|[1-9][0-9]|1[0-9][0-9]|2[0-4][0-9]|25[0-4])(\\.(?!$)|$)){4}$",
              "type": "string"
            }
          }
        }
      ]
    },
    "IpV4Range": {
      "allOf": [
